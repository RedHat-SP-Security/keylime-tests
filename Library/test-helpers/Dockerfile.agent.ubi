FROM docker.io/redhat/ubi9
COPY yumrepogen_setup.sh /root/yumrepogen_setup.sh
RUN \
  chmod a+x /root/yumrepogen_setup.sh && /root/yumrepogen_setup.sh && \
  cat /etc/yum.repos.d/* && \
  dnf install -y keylime-agent-rust util-linux-core which && \
  dnf clean all

EXPOSE 9002
EXPOSE 8892

CMD ["keylime_agent"]
